{
  "name": "healthbridge",
  "module": "index.ts",
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "latest",
    "turbo": "^2.9.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.8",
  "private": true,
  "scripts": {
    "dev": "turbo dev --ui tui",
    "build": "turbo build",
    "typecheck": "turbo typecheck",

{
  "name": "@healthbridge/backend",
  "module": "dist/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch --env-file=.env src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "bun-types": "^1.3.13",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "typescript": "^5.x"
  },
  "dependencies": {
    "@healthbridge/types": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "bcrypt-ts": "^8.0.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.15.1",
    "multer": "^2.1.1",
    "razorpay": "^2.9.6",
    "zod": "^4.3.6"
  }
}
